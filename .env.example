# База данных (Supabase - бесплатно)
# Получить на: https://supabase.com → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# JWT секрет — сгенерировать: openssl rand -base64 32
JWT_SECRET="your-super-secret-key-change-this"

# URL сайта
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# В продакшне: NEXT_PUBLIC_APP_URL="https://yourdomain.ru"

# Почта для формы обратной связи (mail.ru SMTP)
# Пароль приложения: mail.ru → Настройки → Безопасность → Пароли для внешних приложений
MAIL_USER="sgmy7777@mail.ru"
MAIL_PASS="ваш_пароль_приложения_mail_ru"
